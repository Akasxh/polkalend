# ========================================
# PolkaLend Environment Configuration
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real keys.

# --------------- Required for Deployment ---------------

# Deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x_your_private_key_here

# --------------- Optional: RPC Endpoints ---------------
# Override defaults from hardhat.config.js if needed

# Moonbeam mainnet RPC
# MOONBEAM_RPC=https://rpc.api.moonbeam.network

# Moonbase Alpha testnet RPC
# MOONBASE_RPC=https://rpc.api.moonbase.moonbeam.network

# --------------- Optional: Verification ---------------

# Block explorer API key for contract verification
# ETHERSCAN_API_KEY=your_api_key_here

# Moonscan API key (alternative to Etherscan for Moonbeam)
# MOONSCAN_API_KEY=your_moonscan_api_key_here

# --------------- Optional: Gas Reporting ---------------

# Set to true to generate gas usage reports during tests
# REPORT_GAS=true

# CoinMarketCap API key for USD gas cost estimation
# COINMARKETCAP_API_KEY=your_cmc_api_key_here
